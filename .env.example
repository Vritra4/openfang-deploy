# OpenFang Docker Deployment — Environment Variables
# Copy this file to .env and fill in your keys:
#   cp .env.example .env && chmod 600 .env

# OpenFang API access token (auto-generated by build.ts if empty)
# Used for dashboard login and API authentication
OPENFANG_API_KEY=

# Network binding IP address
# If set, this IP is used directly (Tailscale auto-detection is skipped)
# If empty/absent, Tailscale IP is auto-detected, then falls back to 127.0.0.1
# Examples: 100.64.0.1 (Tailscale), 10.147.17.1 (ZeroTier), 192.168.1.100 (LAN)
BIND_IP=

# LLM Provider Keys (fill in at least one)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# Channel Integrations (optional)
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
